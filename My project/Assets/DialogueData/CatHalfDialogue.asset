  m_Script: {fileID: 11500000, guid: c4bd82d48ffa5ba4d9a83cc1c5af521b, type: 3}
  m_Name: CatHalfDialogue
  m_EditorClassIdentifier: 
  dialogueTitle: "\u6536\u96C6\u4E0D\u5168\u9014\u4E2D\u5BF9\u8BDD"
  dialogueLines:
  - dialogueContent: "\u4F60\u627E\u5230\u51E0\u6761\u5566\u3010\u998B\u3011\uFF1F\u6211\u6570\u6570\u2026\u2026emmm\uFF0C\u8FD8\u5DEEX\u6761\u54E6\u3002"
    speaker:
      roleName: "\u732B\u732B"
      roleHead: {fileID: 21300000, guid: 2b4999899f67e494f91cfb44279d261d, type: 3}
      rolePosition: 1
    isMonologue: 0
  - dialogueContent: "\u4E0D\u6025\u4E0D\u6025\uFF0C\u6865\u53C8\u4E0D\u4F1A\u8DD1\u3002\u6162\u6162\u627E\uFF0C\u6162\u6162\u901B\u3002"
    speaker:
      roleName: "\u732B\u732B"
      roleHead: {fileID: 21300000, guid: 2b4999899f67e494f91cfb44279d261d, type: 3}
      rolePosition: 1
    isMonologue: 0
  - dialogueContent: "\u522B\u5149\u53BB\u627E\u5C0F\u9C7C\u5E72\u5440\uFF0C\u591A\u770B\u770B\u8FD9\u5EA7\u6865\uFF0C\u77A7\u77A7\uFF08\u6865\u6865\uFF09\u54B1\u4EEC\u4E2D\u56FD\u53E4\u4EE3\u5EFA\u7B51"
    speaker:
      roleName: "\u732B\u732B"
      roleHead: {fileID: 21300000, guid: 2b4999899f67e494f91cfb44279d261d, type: 3}
      rolePosition: 1
    isMonologue: 0
  - dialogueContent: "\u7ED3\u679C\u56FA\u7136\u91CD\u8981\uFF0C\u8D70\u8FC7\u3001\u770B\u8FC7\u3001\u611F\u53D7\u8FC7\uFF0C\u624D\u6700\u73CD\u8D35\u3002"
    speaker:
      roleName: "\u732B\u732B"
      roleHead: {fileID: 21300000, guid: 2b4999899f67e494f91cfb44279d261d, type: 3}
      rolePosition: 1
    isMonologue: 0
  - dialogueContent: "\u4F60\u521A\u624D\u770B\u4E86\u90A3\u6839\u67F1\u5B50\u4E86\u5417\uFF1F\u5E95\u4E0B\u6253\u4E86\u6728\u6869\u3002\u5343\u5E74\u4E0D\u584C\uFF01\u8001\u7956\u5B97\u771F\u5389\u5BB3\uFF0C\u5BF9\u5427\uFF1F"
    speaker:
      roleName: "\u732B\u732B"
      roleHead: {fileID: 21300000, guid: 2b4999899f67e494f91cfb44279d261d, type: 3}
      rolePosition: 1
    isMonologue: 0
